rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // For simplicity in this initial setup, we'll check if the email matches the provided admin email
      // In a real production app, you'd use a roles collection
      let adminEmails = ['abraunstore@gmail.com', 'andres@jasperdesign.online'];
      return isSignedIn() && (request.auth.token.email in adminEmails && request.auth.token.email_verified == true);
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Settings
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Pages
    match /pages/{pageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Blog
    match /blog/{postId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Gallery
    match /gallery/{imageId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
