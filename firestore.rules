rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // Simplifying admin check to unblock the user.
      // We check if the email matches the authorized list.
      // Note: Removed email_verified check temporarily because user reported issues with verification emails.
      return isSignedIn() && (
        request.auth.token.email == 'abraunstore@gmail.com' || 
        request.auth.token.email == 'andres@jasperdesign.online'
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Settings
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Pages
    match /pages/{pageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Blog
    match /blog/{postId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Gallery
    match /gallery/{imageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Team
    match /team/{memberId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Services
    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // FAQs
    match /faqs/{faqId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Testimonials
    match /testimonials/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
