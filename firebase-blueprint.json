{
  "entities": {
    "siteSettings": {
      "title": "Site Settings",
      "description": "Global configuration for the dental clinic website",
      "type": "object",
      "properties": {
        "clinicName": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "address": { "type": "string" },
        "googleMapsUrl": { "type": "string" },
        "hours": { "type": "array" },
        "logoUrl": { "type": "string" },
        "social": { "type": "object" }
      }
    },
    "pages": {
      "title": "Page Content",
      "description": "Content for specific website pages",
      "type": "object",
      "properties": {
        "slug": { "type": "string" },
        "title": { "type": "string" },
        "sections": { "type": "array" }
      }
    },
    "blogPosts": {
      "title": "Blog Post",
      "description": "Dental health articles and news",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "author": { "type": "string" },
        "date": { "type": "string" },
        "image": { "type": "string" },
        "published": { "type": "boolean" }
      }
    },
    "gallery": {
      "title": "Gallery Image",
      "description": "Images for the smile gallery",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "url": { "type": "string" },
        "category": { "type": "string" }
      }
    },
    "team": {
      "title": "Team Member",
      "description": "Staff and doctors at the clinic",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "specialty": { "type": "string" },
        "description": { "type": "string" },
        "image": { "type": "string" },
        "order": { "type": "number" }
      }
    },
    "services": {
      "title": "Dental Service",
      "description": "Services offered by the clinic",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "icon": { "type": "string" },
        "image": { "type": "string" },
        "category": { "type": "string" },
        "order": { "type": "number" }
      }
    },
    "faqs": {
      "title": "Frequently Asked Question",
      "description": "Website FAQs",
      "type": "object",
      "properties": {
        "question": { "type": "string" },
        "answer": { "type": "string" },
        "order": { "type": "number" }
      }
    },
    "testimonials": {
      "title": "Testimonial",
      "description": "Patient reviews and testimonials",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string" },
        "content": { "type": "string" },
        "rating": { "type": "number" },
        "image": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/settings/global": {
      "schema": "siteSettings",
      "description": "Centralized site configuration"
    },
    "/pages/{pageId}": {
      "schema": "pages",
      "description": "Content for individual pages"
    },
    "/blog/{postId}": {
      "schema": "blogPosts",
      "description": "Blog content collection"
    },
    "/gallery/{imageId}": {
      "schema": "gallery",
      "description": "Gallery images collection"
    },
    "/team/{memberId}": {
      "schema": "team",
      "description": "Team members collection"
    },
    "/services/{serviceId}": {
      "schema": "services",
      "description": "Services collection"
    },
    "/faqs/{faqId}": {
      "schema": "faqs",
      "description": "FAQs collection"
    },
    "/testimonials/{id}": {
      "schema": "testimonials",
      "description": "Testimonials collection"
    }
  }
}
